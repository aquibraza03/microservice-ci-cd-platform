# ==========================================================
# Microservice CI/CD Platform - Production Environment
# File: environments/prod/platform.env
# STRICT NO HARDCODING / Enterprise Ready / Ready to Paste
# All runtime values injected by CI/CD or secret manager
# ==========================================================

# ----------------------------------------------------------
# Core Identity (Required)
# ----------------------------------------------------------
ENV_NAME=prod
ENV_TIER=production
ENV_CLASS=dedicated

PLATFORM_NAME=${PLATFORM_NAME:?required}
ORG_NAME=${ORG_NAME:?required}

# ----------------------------------------------------------
# Multi-Cloud Strategy (Required)
# ----------------------------------------------------------
DEPLOY_CLOUDS=${DEPLOY_CLOUDS:?required}
PRIMARY_CLOUD=${PRIMARY_CLOUD:?required}
ACTIVE_CLOUDS=${ACTIVE_CLOUDS:?required}
FAILOVER_CLOUD=${FAILOVER_CLOUD:-}

# ----------------------------------------------------------
# Runtime Cloud / Regions (Required)
# ----------------------------------------------------------
CLOUD_PROVIDER=${CLOUD_PROVIDER:?required}
PRIMARY_REGION=${PRIMARY_REGION:?required}
SECONDARY_REGION=${SECONDARY_REGION:-}
ACCOUNT_ALIAS=${ACCOUNT_ALIAS:?required}

# ----------------------------------------------------------
# Deployment Target (Required)
# ----------------------------------------------------------
DEPLOY_TARGET=${DEPLOY_TARGET:?required}
CLUSTER_NAME=${CLUSTER_NAME:?required}
K8S_NAMESPACE=${K8S_NAMESPACE:?required}

# ----------------------------------------------------------
# Scaling / Capacity (Required)
# ----------------------------------------------------------
SCALING_PROFILE=${SCALING_PROFILE:?required}
MIN_REPLICAS=${MIN_REPLICAS:?required}
MAX_REPLICAS=${MAX_REPLICAS:?required}

ENABLE_AUTOSCALING=${ENABLE_AUTOSCALING:?required}
TARGET_CPU_UTILIZATION=${TARGET_CPU_UTILIZATION:?required}
TARGET_MEMORY_UTILIZATION=${TARGET_MEMORY_UTILIZATION:?required}

# ----------------------------------------------------------
# Release Controls (Required)
# ----------------------------------------------------------
DEPLOY_STRATEGY=${DEPLOY_STRATEGY:?required}
ENABLE_CANARY=${ENABLE_CANARY:?required}
ENABLE_BLUE_GREEN=${ENABLE_BLUE_GREEN:?required}

AUTO_DEPLOY_ON_MERGE=${AUTO_DEPLOY_ON_MERGE:?required}
AUTO_DEPLOY_ON_RELEASE=${AUTO_DEPLOY_ON_RELEASE:?required}
REQUIRE_APPROVAL=${REQUIRE_APPROVAL:?required}

# ----------------------------------------------------------
# CI/CD Quality Gates (Required)
# ----------------------------------------------------------
RUN_UNIT_TESTS=${RUN_UNIT_TESTS:?required}
RUN_INTEGRATION_TESTS=${RUN_INTEGRATION_TESTS:?required}
RUN_CONTRACT_TESTS=${RUN_CONTRACT_TESTS:?required}
RUN_E2E_TESTS=${RUN_E2E_TESTS:?required}
RUN_SMOKE_TESTS=${RUN_SMOKE_TESTS:?required}
RUN_PERFORMANCE_TESTS=${RUN_PERFORMANCE_TESTS:?required}

# ----------------------------------------------------------
# Security Gates (Required)
# ----------------------------------------------------------
RUN_SAST=${RUN_SAST:?required}
RUN_CONTAINER_SCAN=${RUN_CONTAINER_SCAN:?required}
GENERATE_SBOM=${GENERATE_SBOM:?required}
ALLOW_HIGH_VULNS=${ALLOW_HIGH_VULNS:?required}
ALLOW_CRITICAL_VULNS=${ALLOW_CRITICAL_VULNS:?required}

# ----------------------------------------------------------
# Registry / Images (Required)
# ----------------------------------------------------------
REGISTRY_PROVIDER=${REGISTRY_PROVIDER:?required}
IMAGE_TAG_STRATEGY=${IMAGE_TAG_STRATEGY:?required}
IMAGE_RETENTION_DAYS=${IMAGE_RETENTION_DAYS:?required}

# ----------------------------------------------------------
# Terraform Controls (Required)
# ----------------------------------------------------------
TF_WORKSPACE=${TF_WORKSPACE:?required}
AUTO_APPLY=${AUTO_APPLY:?required}
ALLOW_DESTROY=${ALLOW_DESTROY:?required}
REQUIRE_PLAN_REVIEW=${REQUIRE_PLAN_REVIEW:?required}

# ----------------------------------------------------------
# SCM Governance (Required)
# ----------------------------------------------------------
GIT_PROVIDER=${GIT_PROVIDER:?required}
GITHUB_ORG=${GITHUB_ORG:?required}
GITHUB_REPO=${GITHUB_REPO:?required}
DEFAULT_BRANCH=${DEFAULT_BRANCH:?required}

BRANCH_PROTECTION=${BRANCH_PROTECTION:?required}
REQUIRE_PR_REVIEWS=${REQUIRE_PR_REVIEWS:?required}
REQUIRE_STATUS_CHECKS=${REQUIRE_STATUS_CHECKS:?required}
AUTO_MERGE=${AUTO_MERGE:?required}

# ----------------------------------------------------------
# GitOps Controls
# ----------------------------------------------------------
GITOPS_ENABLED=${GITOPS_ENABLED:?required}
GITOPS_TOOL=${GITOPS_TOOL:-}
GITOPS_REPO=${GITOPS_REPO:-}
GITOPS_BRANCH=${GITOPS_BRANCH:-}

# ----------------------------------------------------------
# Observability (Required)
# ----------------------------------------------------------
ENABLE_MONITORING=${ENABLE_MONITORING:?required}
ENABLE_LOGGING=${ENABLE_LOGGING:?required}
ENABLE_TRACING=${ENABLE_TRACING:?required}
ENABLE_ALERTING=${ENABLE_ALERTING:?required}

# ----------------------------------------------------------
# Logging (Required)
# ----------------------------------------------------------
APP_LOG_LEVEL=${APP_LOG_LEVEL:?required}
PLATFORM_LOG_LEVEL=${PLATFORM_LOG_LEVEL:?required}

# ----------------------------------------------------------
# Networking (Required)
# ----------------------------------------------------------
PUBLIC_ACCESS=${PUBLIC_ACCESS:?required}
INGRESS_CLASS=${INGRESS_CLASS:?required}
TLS_ENABLED=${TLS_ENABLED:?required}
WAF_ENABLED=${WAF_ENABLED:?required}

# ----------------------------------------------------------
# Reliability / DR (Required)
# ----------------------------------------------------------
MULTI_AZ_ENABLED=${MULTI_AZ_ENABLED:?required}
DR_ENABLED=${DR_ENABLED:?required}
RTO_MINUTES=${RTO_MINUTES:?required}
RPO_MINUTES=${RPO_MINUTES:?required}

# ----------------------------------------------------------
# Cost Controls (Required)
# ----------------------------------------------------------
SPOT_ENABLED=${SPOT_ENABLED:?required}
OFF_HOURS_SCALE_DOWN=${OFF_HOURS_SCALE_DOWN:?required}
IDLE_TIMEOUT_MINUTES=${IDLE_TIMEOUT_MINUTES:?required}

# ----------------------------------------------------------
# Compliance / Backup (Required)
# ----------------------------------------------------------
BACKUP_REQUIRED=${BACKUP_REQUIRED:?required}
RETENTION_DAYS=${RETENTION_DAYS:?required}
AUDIT_LOGGING=${AUDIT_LOGGING:?required}

# ----------------------------------------------------------
# Notifications (Required)
# ----------------------------------------------------------
SLACK_NOTIFICATIONS=${SLACK_NOTIFICATIONS:?required}
EMAIL_NOTIFICATIONS=${EMAIL_NOTIFICATIONS:?required}
PAGER_NOTIFICATIONS=${PAGER_NOTIFICATIONS:?required}

# ----------------------------------------------------------
# Ownership (Required)
# ----------------------------------------------------------
OWNER_TEAM=${OWNER_TEAM:?required}
CONTACT_CHANNEL=${CONTACT_CHANNEL:?required}

# ----------------------------------------------------------
# Change Management (Required)
# ----------------------------------------------------------
CHANGE_WINDOW=${CHANGE_WINDOW:?required}
FREEZE_WINDOW_ENABLED=${FREEZE_WINDOW_ENABLED:?required}

# ----------------------------------------------------------
# Metadata (Injected by CI/CD)
# ----------------------------------------------------------
LAST_UPDATED=${LAST_UPDATED:?required}
DEPLOYED_BY=${DEPLOYED_BY:?required}
BUILD_ID=${BUILD_ID:?required}
GIT_SHA=${GIT_SHA:?required}
