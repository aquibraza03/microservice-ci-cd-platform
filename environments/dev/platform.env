# ==========================================================
# Microservice CI/CD Platform - Development Environment
# File: environments/dev/platform.env
# Enterprise Ready / Ready to Paste
# ==========================================================

# ----------------------------------------------------------
# Core Identity
# ----------------------------------------------------------
ENV_NAME=dev
ENV_TIER=nonprod
ENV_CLASS=shared
PLATFORM_NAME=microservice-ci-cd-platform
ORG_NAME=your-org

# ----------------------------------------------------------
# Multi-Cloud Strategy
# ----------------------------------------------------------
DEPLOY_CLOUDS=aws,gcp,azure
PRIMARY_CLOUD=aws
ACTIVE_CLOUDS=aws
FAILOVER_CLOUD=

# ----------------------------------------------------------
# Cloud Provider Runtime
# ----------------------------------------------------------
CLOUD_PROVIDER=aws
PRIMARY_REGION=ap-south-1
SECONDARY_REGION=ap-southeast-1
ACCOUNT_ALIAS=dev-account

# ----------------------------------------------------------
# Deployment Target
# Options: eks | ecs | aks | gke | k8s
# ----------------------------------------------------------
DEPLOY_TARGET=eks
CLUSTER_NAME=platform-dev
K8S_NAMESPACE=platform-dev

# ----------------------------------------------------------
# Scaling Profile
# Options: startup | growth | enterprise
# Actual cpu/memory loaded from profile catalog
# ----------------------------------------------------------
SCALING_PROFILE=startup
MIN_REPLICAS=1
MAX_REPLICAS=2

# ----------------------------------------------------------
# Autoscaling
# ----------------------------------------------------------
ENABLE_AUTOSCALING=true
TARGET_CPU_UTILIZATION=70
TARGET_MEMORY_UTILIZATION=75

# ----------------------------------------------------------
# Release Strategy
# ----------------------------------------------------------
DEPLOY_STRATEGY=rolling
ENABLE_CANARY=false
ENABLE_BLUE_GREEN=false
AUTO_DEPLOY_ON_MERGE=true
REQUIRE_APPROVAL=false

# ----------------------------------------------------------
# CI/CD Controls
# ----------------------------------------------------------
RUN_UNIT_TESTS=true
RUN_INTEGRATION_TESTS=true
RUN_CONTRACT_TESTS=false
RUN_E2E_TESTS=false
RUN_SMOKE_TESTS=true

# ----------------------------------------------------------
# Security Controls
# ----------------------------------------------------------
RUN_SAST=true
RUN_CONTAINER_SCAN=true
GENERATE_SBOM=true
ALLOW_HIGH_VULNS=true
ALLOW_CRITICAL_VULNS=false

# ----------------------------------------------------------
# Registry / Image Strategy
# Options: git-sha | semver | branch-sha | release-tag
# ----------------------------------------------------------
REGISTRY_PROVIDER=ecr
IMAGE_TAG_STRATEGY=git-sha
IMAGE_RETENTION_DAYS=15

# ----------------------------------------------------------
# Terraform Controls
# ----------------------------------------------------------
TF_WORKSPACE=dev
AUTO_APPLY=true
ALLOW_DESTROY=true

# ----------------------------------------------------------
# Git Provider / Repo Controls
# ----------------------------------------------------------
GIT_PROVIDER=github
GITHUB_ORG=your-org
GITHUB_REPO=microservice-ci-cd-platform
DEFAULT_BRANCH=main
BRANCH_PROTECTION=true
REQUIRE_PR_REVIEWS=true
REQUIRE_STATUS_CHECKS=true
AUTO_MERGE=false

# ----------------------------------------------------------
# GitOps Controls
# ----------------------------------------------------------
GITOPS_ENABLED=false
GITOPS_TOOL=
GITOPS_REPO=
GITOPS_BRANCH=main

# ----------------------------------------------------------
# Observability
# ----------------------------------------------------------
ENABLE_MONITORING=true
ENABLE_LOGGING=true
ENABLE_TRACING=false
ENABLE_ALERTING=false

# ----------------------------------------------------------
# Logging Levels
# ----------------------------------------------------------
APP_LOG_LEVEL=debug
PLATFORM_LOG_LEVEL=info

# ----------------------------------------------------------
# Networking
# ----------------------------------------------------------
PUBLIC_ACCESS=false
INGRESS_CLASS=nginx
TLS_ENABLED=false

# ----------------------------------------------------------
# Cost Controls
# ----------------------------------------------------------
SPOT_ENABLED=true
OFF_HOURS_SCALE_DOWN=true
IDLE_TIMEOUT_MINUTES=30

# ----------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------
ENABLE_EXPERIMENTAL_FEATURES=true
ENABLE_PREVIEW_DEPLOYS=true

# ----------------------------------------------------------
# Compliance / Retention
# ----------------------------------------------------------
BACKUP_REQUIRED=false
RETENTION_DAYS=7
AUDIT_LOGGING=false

# ----------------------------------------------------------
# Notifications
# ----------------------------------------------------------
SLACK_NOTIFICATIONS=true
EMAIL_NOTIFICATIONS=false

# ----------------------------------------------------------
# Ownership
# ----------------------------------------------------------
OWNER_TEAM=platform-engineering
CONTACT_CHANNEL=#devops

# ----------------------------------------------------------
# Metadata
# ----------------------------------------------------------
LAST_UPDATED=2026-04-17
