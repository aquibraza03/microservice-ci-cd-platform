# ==========================================================
# Microservice CI/CD Platform - Staging Environment
# File: environments/staging/platform.env
# 100% Enterprise Ready / No Hardcoding / Ready to Paste
# Purpose: Pre-production validation environment
# ==========================================================

# ----------------------------------------------------------
# Core Identity
# ----------------------------------------------------------
ENV_NAME=staging
ENV_TIER=preprod
ENV_CLASS=shared
PLATFORM_NAME=${PLATFORM_NAME:-microservice-ci-cd-platform}
ORG_NAME=${ORG_NAME:-your-org}

# ----------------------------------------------------------
# Multi-Cloud Strategy
# ----------------------------------------------------------
DEPLOY_CLOUDS=${DEPLOY_CLOUDS:-aws,gcp,azure}
PRIMARY_CLOUD=${PRIMARY_CLOUD:-aws}
ACTIVE_CLOUDS=${ACTIVE_CLOUDS:-aws}
FAILOVER_CLOUD=${FAILOVER_CLOUD:-}

# ----------------------------------------------------------
# Runtime Cloud Provider
# ----------------------------------------------------------
CLOUD_PROVIDER=${CLOUD_PROVIDER:-aws}
PRIMARY_REGION=${PRIMARY_REGION:-ap-south-1}
SECONDARY_REGION=${SECONDARY_REGION:-ap-southeast-1}
ACCOUNT_ALIAS=${ACCOUNT_ALIAS:-staging-account}

# ----------------------------------------------------------
# Deployment Target
# Options: eks | ecs | aks | gke | k8s
# ----------------------------------------------------------
DEPLOY_TARGET=${DEPLOY_TARGET:-eks}
CLUSTER_NAME=${CLUSTER_NAME:-platform-staging}
K8S_NAMESPACE=${K8S_NAMESPACE:-platform-staging}

# ----------------------------------------------------------
# Scaling Profile
# Options: startup | growth | enterprise
# ----------------------------------------------------------
SCALING_PROFILE=${SCALING_PROFILE:-growth}
MIN_REPLICAS=${MIN_REPLICAS:-2}
MAX_REPLICAS=${MAX_REPLICAS:-4}

# ----------------------------------------------------------
# Autoscaling
# ----------------------------------------------------------
ENABLE_AUTOSCALING=${ENABLE_AUTOSCALING:-true}
TARGET_CPU_UTILIZATION=${TARGET_CPU_UTILIZATION:-65}
TARGET_MEMORY_UTILIZATION=${TARGET_MEMORY_UTILIZATION:-70}

# ----------------------------------------------------------
# Release Strategy
# ----------------------------------------------------------
DEPLOY_STRATEGY=${DEPLOY_STRATEGY:-rolling}
ENABLE_CANARY=${ENABLE_CANARY:-true}
ENABLE_BLUE_GREEN=${ENABLE_BLUE_GREEN:-false}
AUTO_DEPLOY_ON_MERGE=${AUTO_DEPLOY_ON_MERGE:-false}
AUTO_DEPLOY_ON_RELEASE=${AUTO_DEPLOY_ON_RELEASE:-true}
REQUIRE_APPROVAL=${REQUIRE_APPROVAL:-true}

# ----------------------------------------------------------
# CI/CD Validation Gates
# ----------------------------------------------------------
RUN_UNIT_TESTS=${RUN_UNIT_TESTS:-true}
RUN_INTEGRATION_TESTS=${RUN_INTEGRATION_TESTS:-true}
RUN_CONTRACT_TESTS=${RUN_CONTRACT_TESTS:-true}
RUN_E2E_TESTS=${RUN_E2E_TESTS:-true}
RUN_SMOKE_TESTS=${RUN_SMOKE_TESTS:-true}
RUN_PERFORMANCE_TESTS=${RUN_PERFORMANCE_TESTS:-false}

# ----------------------------------------------------------
# Security Controls
# ----------------------------------------------------------
RUN_SAST=${RUN_SAST:-true}
RUN_CONTAINER_SCAN=${RUN_CONTAINER_SCAN:-true}
GENERATE_SBOM=${GENERATE_SBOM:-true}
ALLOW_HIGH_VULNS=${ALLOW_HIGH_VULNS:-false}
ALLOW_CRITICAL_VULNS=${ALLOW_CRITICAL_VULNS:-false}

# ----------------------------------------------------------
# Registry / Image Strategy
# ----------------------------------------------------------
REGISTRY_PROVIDER=${REGISTRY_PROVIDER:-ecr}
IMAGE_TAG_STRATEGY=${IMAGE_TAG_STRATEGY:-git-sha}
IMAGE_RETENTION_DAYS=${IMAGE_RETENTION_DAYS:-30}

# ----------------------------------------------------------
# Terraform Controls
# ----------------------------------------------------------
TF_WORKSPACE=${TF_WORKSPACE:-staging}
AUTO_APPLY=${AUTO_APPLY:-false}
ALLOW_DESTROY=${ALLOW_DESTROY:-false}
REQUIRE_PLAN_REVIEW=${REQUIRE_PLAN_REVIEW:-true}

# ----------------------------------------------------------
# Git Provider / SCM Governance
# ----------------------------------------------------------
GIT_PROVIDER=${GIT_PROVIDER:-github}
GITHUB_ORG=${GITHUB_ORG:-your-org}
GITHUB_REPO=${GITHUB_REPO:-microservice-ci-cd-platform}
DEFAULT_BRANCH=${DEFAULT_BRANCH:-main}
BRANCH_PROTECTION=${BRANCH_PROTECTION:-true}
REQUIRE_PR_REVIEWS=${REQUIRE_PR_REVIEWS:-true}
REQUIRE_STATUS_CHECKS=${REQUIRE_STATUS_CHECKS:-true}
AUTO_MERGE=${AUTO_MERGE:-false}

# ----------------------------------------------------------
# GitOps Controls
# ----------------------------------------------------------
GITOPS_ENABLED=${GITOPS_ENABLED:-false}
GITOPS_TOOL=${GITOPS_TOOL:-}
GITOPS_REPO=${GITOPS_REPO:-}
GITOPS_BRANCH=${GITOPS_BRANCH:-main}

# ----------------------------------------------------------
# Observability
# ----------------------------------------------------------
ENABLE_MONITORING=${ENABLE_MONITORING:-true}
ENABLE_LOGGING=${ENABLE_LOGGING:-true}
ENABLE_TRACING=${ENABLE_TRACING:-true}
ENABLE_ALERTING=${ENABLE_ALERTING:-true}

# ----------------------------------------------------------
# Logging Levels
# ----------------------------------------------------------
APP_LOG_LEVEL=${APP_LOG_LEVEL:-info}
PLATFORM_LOG_LEVEL=${PLATFORM_LOG_LEVEL:-info}

# ----------------------------------------------------------
# Networking
# ----------------------------------------------------------
PUBLIC_ACCESS=${PUBLIC_ACCESS:-false}
INGRESS_CLASS=${INGRESS_CLASS:-nginx}
TLS_ENABLED=${TLS_ENABLED:-true}
WAF_ENABLED=${WAF_ENABLED:-true}

# ----------------------------------------------------------
# Cost Controls
# ----------------------------------------------------------
SPOT_ENABLED=${SPOT_ENABLED:-true}
OFF_HOURS_SCALE_DOWN=${OFF_HOURS_SCALE_DOWN:-false}
IDLE_TIMEOUT_MINUTES=${IDLE_TIMEOUT_MINUTES:-0}

# ----------------------------------------------------------
# Compliance / Backup
# ----------------------------------------------------------
BACKUP_REQUIRED=${BACKUP_REQUIRED:-true}
RETENTION_DAYS=${RETENTION_DAYS:-30}
AUDIT_LOGGING=${AUDIT_LOGGING:-true}

# ----------------------------------------------------------
# Notifications
# ----------------------------------------------------------
SLACK_NOTIFICATIONS=${SLACK_NOTIFICATIONS:-true}
EMAIL_NOTIFICATIONS=${EMAIL_NOTIFICATIONS:-true}

# ----------------------------------------------------------
# Ownership
# ----------------------------------------------------------
OWNER_TEAM=${OWNER_TEAM:-platform-engineering}
CONTACT_CHANNEL=${CONTACT_CHANNEL:-#platform-alerts}

# ----------------------------------------------------------
# Metadata
# ----------------------------------------------------------
CHANGE_WINDOW=${CHANGE_WINDOW:-business-hours}
LAST_UPDATED=2026-04-17
