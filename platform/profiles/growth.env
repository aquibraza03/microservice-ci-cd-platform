# ==================================================
# 📈 GROWTH PROFILE (Scalable / Production-ready)
# ==================================================
# Purpose:
# Enable horizontal scaling, resilience, and performance tuning.
# Overrides only what is necessary from defaults.

# ==================================================
# 🧠 COMPUTE SCALING (relative increase)
# ==================================================
CPU=1000m
MEMORY=1Gi
REPLICAS=3

# ==================================================
# 📈 AUTOSCALING ENABLED
# ==================================================
AUTOSCALE_ENABLED=true

# Scaling bounds (relative, not environment-specific)
AUTOSCALE_MIN_REPLICAS=2
AUTOSCALE_MAX_REPLICAS=10

# Trigger behavior (percentage-based → portable)
AUTOSCALE_CPU_THRESHOLD=70

# ==================================================
# 📊 OBSERVABILITY (full enabled)
# ==================================================
TRACING_ENABLED=true
METRICS_ENABLED=true

# ==================================================
# 🚀 DEPLOYMENT STRATEGY (resilient)
# ==================================================
DEPLOYMENT_STRATEGY=rolling
MAX_UNAVAILABLE=0
MAX_SURGE=1

# ==================================================
# 🧪 FEATURE FLAGS (advanced rollout enabled)
# ==================================================
FEATURE_CANARY=true
FEATURE_BLUE_GREEN=false

# ==================================================
# 🧬 PROFILE METADATA (for platform logic)
# ==================================================
PLATFORM_PROFILE=growth
PLATFORM_PROFILE_CLASS=scalable
PLATFORM_SCALING_MODE=auto
