# ==================================================
# 🚀 STARTUP PROFILE (Low-cost / Early-stage)
# ==================================================
# Purpose:
# Optimize for low resource usage and minimal cost.
# Inherits all defaults unless explicitly overridden.

# ==================================================
# 🧠 COMPUTE OVERRIDES
# ==================================================
CPU=250m
MEMORY=256Mi
REPLICAS=1

# ==================================================
# 📈 AUTOSCALING STRATEGY
# ==================================================
AUTOSCALE_ENABLED=false

# ==================================================
# 📊 OBSERVABILITY (reduced footprint)
# ==================================================
TRACING_ENABLED=false

# ==================================================
# 🚀 DEPLOYMENT BEHAVIOR
# ==================================================
DEPLOYMENT_STRATEGY=rolling

# ==================================================
# 🧪 FEATURE FLAGS
# ==================================================
FEATURE_CANARY=false
FEATURE_BLUE_GREEN=false

# ==================================================
# 🧬 PROFILE METADATA (important for platform logic)
# ==================================================
PLATFORM_PROFILE=startup
PLATFORM_PROFILE_CLASS=cost-optimized
