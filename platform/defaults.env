# ==================================================
# 🌍 PLATFORM DEFAULT CONFIGURATION (BASELINE)
# ==================================================
# This file defines the default runtime behavior for all services.
# Profiles and runtime overrides can change these values.

# ==================================================
# 🧠 COMPUTE (Resource Allocation)
# ==================================================
CPU=500m
MEMORY=512Mi
REPLICAS=1

# ==================================================
# 📈 AUTOSCALING (Disabled by default)
# ==================================================
AUTOSCALE_ENABLED=false
AUTOSCALE_MIN_REPLICAS=1
AUTOSCALE_MAX_REPLICAS=3
AUTOSCALE_CPU_THRESHOLD=70

# ==================================================
# 🌐 NETWORK / SERVICE
# ==================================================
SERVICE_PORT=3000
SERVICE_TIMEOUT=30
SERVICE_RETRIES=3

# ==================================================
# 📊 OBSERVABILITY
# ==================================================
LOG_LEVEL=info
METRICS_ENABLED=true
TRACING_ENABLED=false

# ==================================================
# 🔐 SECURITY
# ==================================================
SECURITY_CONTEXT_ENABLED=true
READ_ONLY_ROOT_FS=true

# ==================================================
# 🐳 CONTAINER RUNTIME
# ==================================================
CONTAINER_REGISTRY=local
IMAGE_PULL_POLICY=IfNotPresent

# ==================================================
# 🚀 DEPLOYMENT STRATEGY
# ==================================================
DEPLOYMENT_STRATEGY=rolling
MAX_UNAVAILABLE=1
MAX_SURGE=1

# ==================================================
# 🧪 FEATURE FLAGS (Future-ready)
# ==================================================
FEATURE_CANARY=false
FEATURE_BLUE_GREEN=false

# ==================================================
# 🧬 PLATFORM METADATA
# ==================================================
PLATFORM_PROFILE=default
PLATFORM_VERSION=1
