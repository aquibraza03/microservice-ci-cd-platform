# ==================================================
# 🌍 PLATFORM CONFIG SCHEMA (ENTERPRISE)
# ==================================================
# Format:
# VAR=type:required:min:max:pattern

# ==================================================
# 🧠 COMPUTE
# ==================================================
CPU=string:true
MEMORY=string:true
REPLICAS=number:true:1:100

# ==================================================
# 📈 AUTOSCALING
# ==================================================
AUTOSCALE_ENABLED=boolean:false
AUTOSCALE_MIN_REPLICAS=number:false:1:100
AUTOSCALE_MAX_REPLICAS=number:false:1:100
AUTOSCALE_CPU_THRESHOLD=number:false:1:100

# ==================================================
# 🌐 SERVICE
# ==================================================
SERVICE_PORT=number:false:1:65535
SERVICE_TIMEOUT=number:false:1:300
SERVICE_RETRIES=number:false:0:10

# ==================================================
# 📊 OBSERVABILITY
# ==================================================
LOG_LEVEL=string:false
METRICS_ENABLED=boolean:false
TRACING_ENABLED=boolean:false

# ==================================================
# 🔐 SECURITY
# ==================================================
SECURITY_CONTEXT_ENABLED=boolean:false
READ_ONLY_ROOT_FS=boolean:false

# ==================================================
# 🚀 DEPLOYMENT
# ==================================================
DEPLOYMENT_STRATEGY=string:false
MAX_UNAVAILABLE=string:false
MAX_SURGE=string:false

# ==================================================
# 🧪 FEATURE FLAGS
# ==================================================
FEATURE_CANARY=boolean:false
FEATURE_BLUE_GREEN=boolean:false

# ==================================================
# 🧬 METADATA
# ==================================================
PLATFORM_PROFILE=string:true
PLATFORM_VERSION=number:true:1:10
