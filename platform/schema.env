# ==================================================
# 🌍 PLATFORM CONFIG SCHEMA (ENTERPRISE)
# ==================================================
# Format:
# VAR=type:required:min:max:default

# ==================================================
# 🧠 COMPUTE
# ==================================================
CPU=number:true:::512
MEMORY=number:true:::1024
REPLICAS=number:true:::1

# ==================================================
# 📈 AUTOSCALING
# ==================================================
AUTOSCALE_ENABLED=boolean:false:::false
AUTOSCALE_MIN_REPLICAS=number:false:::1
AUTOSCALE_MAX_REPLICAS=number:false:::5
AUTOSCALE_CPU_THRESHOLD=number:false:::70

# ==================================================
# 🌐 SERVICE
# ==================================================
SERVICE_PORT=port:false:::3000
SERVICE_TIMEOUT=number:false:::30
SERVICE_RETRIES=number:false:::3

# ==================================================
# 📊 OBSERVABILITY
# ==================================================
LOG_LEVEL=string:false:::info
METRICS_ENABLED=boolean:false:::true
TRACING_ENABLED=boolean:false:::false

# ==================================================
# 🔐 SECURITY
# ==================================================
SECURITY_CONTEXT_ENABLED=boolean:false:::true
READ_ONLY_ROOT_FS=boolean:false:::true

# ==================================================
# 🚀 DEPLOYMENT
# ==================================================
DEPLOYMENT_STRATEGY=string:false:::rolling
MAX_UNAVAILABLE=string:false:::25%
MAX_SURGE=string:false:::25%

# ==================================================
# 🧪 FEATURE FLAGS
# ==================================================
FEATURE_CANARY=boolean:false:::false
FEATURE_BLUE_GREEN=boolean:false:::false

# ==================================================
# 🧬 METADATA
# ==================================================
PLATFORM_PROFILE=string:true:::dev
PLATFORM_VERSION=number:true:::1
